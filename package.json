{
  "name": "qa-automation-test",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + TypeScript QA automation framework for Sauce Demo, OpenMRS, ReqRes, accessibility, and TestRail reporting.",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test tests/api",
    "test:a11y": "playwright test tests/e2e/accessibility",
    "test:healthcare": "playwright test tests/e2e/healthcare",
    "test:headed": "playwright test --headed",
    "test:ci": "playwright test --project=chromium",
    "report:html": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa",
    "testrail",
    "accessibility",
    "api-testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.4.0",
    "playwright-testrail-reporter": "^1.3.3",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
